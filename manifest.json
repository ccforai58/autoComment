{
  "manifest_version": 3,
  "name": "Auto Register Filler",
  "version": "1.5.1",
  "description": "自动填充注册表单，并为当前网站生成推广文案。",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Auto Register Filler - 网站自动填表与推广文案助手"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension-config.js", "illegal-site-filter.js", "lib/link-assistant-runtime-logic.js", "lib/link-assistant-form-detector.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
