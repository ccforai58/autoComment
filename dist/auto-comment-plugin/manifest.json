{
  "manifest_version": 3,
  "name": "BacklinkAssistant",
  "version": "1.0.0",
  "description": "自动填充注册表单，并为当前网站生成推广文案。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "BacklinkAssistant - 网站自动填表与推广文案助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension-config.js", "illegal-site-filter.js", "lib/link-assistant-runtime-logic.js", "lib/link-assistant-form-detector.js", "lib/manual-assistant-field-logic.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
