{
  "name": "auto-comment-backend",
  "version": "1.0.0",
  "description": "Auto Comment Filler Backend API",
  "main": "server.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "node server.js",
    "dev": "node server.js",
    "local:db:start": "docker compose up -d mysql",
    "local:db:stop": "docker compose stop mysql",
    "local:db:logs": "docker compose logs -f mysql",
    "local:db:setup": "node scripts/setup-local-db.js",
    "local:init-user": "node scripts/init-local-user.js",
    "local:stack:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-stack.ps1",
    "local:stack:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-local-stack.ps1",
    "local:autostart:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-autostart.ps1",
    "local:autostart:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-autostart.ps1",
    "csv:export": "node scripts/run-csv-export.js",
    "pm2:start": "pm2 start server.js --name auto-comment-api",
    "pm2:stop": "pm2 stop auto-comment-api",
    "pm2:restart": "pm2 restart auto-comment-api",
    "pm2:logs": "pm2 logs auto-comment-api"
  },
  "dependencies": {
    "alipay-sdk": "^4.14.0",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mysql2": "^3.11.0",
    "papaparse": "^5.5.3"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
